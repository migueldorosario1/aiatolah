---
import Layout from '../../layouts/Layout.astro';

const modules = import.meta.glob('./posts/*.md', { eager: true });

const posts = Object.entries(modules)
  .map(([path, mod]: [string, any]) => {
    const fm = mod.frontmatter ?? {};
    const slug = path.replace('./posts/', '').replace('.md', '');
    return {
      title:    fm.title ?? slug,
      date:     fm.date ?? '2026-01-01',
      category: fm.category ?? 'AI',
      excerpt:  fm.excerpt ?? '',
      url:      `/pt/posts/${slug}`,
      lang:     fm.lang ?? '',
    };
  })
  .filter(p => p.lang === 'pt-br')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);
---

<Layout
  title="Rankings e Notícias de IA"
  description="AIatolah — Rankings independentes, preços e notícias sobre modelos de IA e LLMs. China vs EUA. Perspectiva do Sul Global."
>
  <main class="container">

    <section class="hero glass-panel animate-fade-in">
      <h1 class="hero-title">O ranking de <span class="ai-cyan">IA</span> que não<br/>toma partido.</h1>
      <p class="hero-sub">
        Compare LLMs chineses e americanos em qualidade, preço e velocidade.
        Geopolítica dos chips, grandes investimentos e modelos de fronteira —
        numa perspectiva multilateral, do Sul Global.
      </p>
      <div class="action-buttons">
        <a href="/pt/rankings" class="btn-neon">Rankings</a>
        <a href="/pt/news" class="btn-outline">Últimas Notícias</a>
        <a href="/pt/about" class="btn-outline">Sobre</a>
      </div>
    </section>

    <section class="columns animate-fade-in">

      <div class="col glass-panel">
        <h2 class="col-title china">🇨🇳 China</h2>
        <div class="model-list">
          <div class="model-item">
            <span class="model-name">DeepSeek V3</span>
            <span class="model-tag best-value">Melhor custo</span>
          </div>
          <div class="model-item">
            <span class="model-name">Qwen 3 Max</span>
            <span class="model-tag">Alibaba</span>
          </div>
          <div class="model-item">
            <span class="model-name">Kimi K2</span>
            <span class="model-tag">Moonshot</span>
          </div>
          <div class="model-item">
            <span class="model-name">GLM-4</span>
            <span class="model-tag">Zhipu</span>
          </div>
        </div>
        <a href="/pt/rankings" class="col-cta">Ranking completo →</a>
      </div>

      <div class="col col-center glass-panel">
        <h2 class="col-title news-title">📡 Últimas</h2>
        <div class="news-placeholder">
          {posts.length === 0 ? (
            <>
              <p class="news-item">Notícias de IA atualizadas a cada 3 horas.</p>
              <p class="news-item muted">Rankings, lançamentos, guerra dos chips, geopolítica.</p>
            </>
          ) : (
            posts.map(post => (
              <article class="news-item-mini" style="display: flex; flex-direction: column; gap: 0.2rem; margin-bottom: 0.8rem;">
                <div style="display: flex; gap: 0.5rem; font-size: 0.72rem; color: rgba(255,255,255,0.4); font-family: 'Outfit', sans-serif;">
                  <span style="color: #00d4ff; font-weight: 700;">{post.category}</span>
                  <span>·</span>
                  <span>{new Date(post.date).toLocaleDateString('pt-BR', { month: 'short', day: 'numeric' })}</span>
                </div>
                <h3 style="font-family: 'Outfit', sans-serif; font-size: 0.95rem; font-weight: 700; line-height: 1.3; margin: 0;">
                  <a href={post.url} style="color: rgba(255,255,255,0.9); text-decoration: none; transition: color 0.2s;" class="hover-cyan">{post.title}</a>
                </h3>
              </article>
            ))
          )}
          <a href="/pt/news" class="col-cta" style="margin-top: auto;">Ver notícias →</a>
        </div>
      </div>

      <div class="col glass-panel">
        <h2 class="col-title usa">🇺🇸 EUA</h2>
        <div class="model-list">
          <div class="model-item">
            <span class="model-name">Claude Sonnet</span>
            <span class="model-tag">Anthropic</span>
          </div>
          <div class="model-item">
            <span class="model-name">GPT-4o</span>
            <span class="model-tag">OpenAI</span>
          </div>
          <div class="model-item">
            <span class="model-name">Gemini 1.5 Pro</span>
            <span class="model-tag">Google</span>
          </div>
          <div class="model-item">
            <span class="model-name">Llama 3.3 70B</span>
            <span class="model-tag best-open">Open source</span>
          </div>
        </div>
        <a href="/pt/rankings" class="col-cta">Ranking completo →</a>
      </div>

    </section>

  </main>
</Layout>

<style>
  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .hero {
    text-align: center;
    padding: 4rem 2rem;
  }

  .hero-title {
    font-family: 'Outfit', sans-serif;
    font-size: 3.2rem;
    font-weight: 900;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    letter-spacing: -1.5px;
  }

  .ai-cyan { color: #00d4ff; }

  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.6);
    max-width: 680px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .action-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-outline {
    display: inline-block;
    color: rgba(255,255,255,0.8);
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    padding: 0.7rem 1.4rem;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    border-color: rgba(0, 212, 255, 0.5);
    color: #00d4ff;
    background: rgba(0, 212, 255, 0.06);
  }

  .columns {
    display: grid;
    grid-template-columns: 1fr 1.1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .col {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .col-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .china { color: #ff6b35; }
  .usa   { color: #4da6ff; }
  .news-title { color: #00d4ff; }

  .model-list { display: flex; flex-direction: column; gap: 0.6rem; }

  .model-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.7rem;
    border-radius: 7px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
  }

  .model-name {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
  }

  .model-tag {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.05);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .best-value { color: #00d4ff; background: rgba(0,212,255,0.1); }
  .best-open  { color: #7b2ff7; background: rgba(123,47,247,0.1); }

  .col-cta {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(0,212,255,0.7);
    text-decoration: none;
    margin-top: auto;
    transition: color 0.2s;
  }

  .col-cta:hover { color: #00d4ff; }
  .col-center { align-items: flex-start; }

  .news-placeholder { display: flex; flex-direction: column; gap: 0.75rem; flex: 1; }

  .news-item {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
  }

  .news-item.muted { color: rgba(255,255,255,0.35); font-size: 0.83rem; }

  @media (max-width: 900px) {
    .columns { grid-template-columns: 1fr; }
    .hero-title { font-size: 2.2rem; }
  }

  @media (max-width: 600px) {
    .container { padding: 2rem 1rem; }
    .hero { padding: 2.5rem 1rem; }
  }
</style>
